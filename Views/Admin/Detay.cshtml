@model KcetasWeb.Models.entities.Kullanici

@{
    ViewData["Title"] = "Personel Detayı";

    string RolEtiketi(string? rolAdi) => rolAdi switch
    {
        "Yonetici" => "Yönetici",
        "Kullanici" => "Personel",
        "Abone" => "Abone",
        _ => rolAdi ?? "Tanımsız"
    };
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 text-primary fw-bold">
            <i class="bi bi-person-badge me-2"></i> Personel Detayı
        </h2>
        <a href="/Admin/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Listeye Dön
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-gradient bg-primary text-white p-4">
            <div class="d-flex align-items-center">
                <div class="bg-white text-primary rounded-circle d-flex justify-content-center align-items-center shadow-sm" style="width: 60px; height: 60px; font-size: 24px; font-weight: bold;">
                    @Model.ad_soyad.Substring(0, 1)
                </div>
                <div class="ms-3">
                    <h3 class="mb-0">@Model.ad_soyad</h3>
                    <p class="mb-0 opacity-75">@RolEtiketi(Model.Rol?.rol_adi)</p>
                </div>
                <div class="ms-auto">
                    @if (Model.durum == "AKTIF")
                    {
                        <span class="badge bg-success rounded-pill px-3 py-2 fs-6 shadow-sm"><i class="bi bi-check-circle me-1"></i> Aktif</span>
                    }
                    else
                    {
                        <span class="badge bg-danger rounded-pill px-3 py-2 fs-6 shadow-sm"><i class="bi bi-x-circle me-1"></i> Pasif</span>
                    }
                </div>
            </div>
        </div>
        <div class="card-body p-4 bg-light">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="p-3 bg-white rounded-3 shadow-sm border border-light">
                        <label class="text-muted small fw-bold mb-1 text-uppercase">Personel ID</label>
                        <p class="fs-5 fw-medium text-dark mb-0">#@Model.kullanici_id</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 bg-white rounded-3 shadow-sm border border-light">
                        <label class="text-muted small fw-bold mb-1 text-uppercase">Kullanıcı Adı</label>
                        <p class="fs-5 fw-medium text-dark mb-0">@Model.kullanici_adi</p>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="p-3 bg-white rounded-3 shadow-sm border border-light">
                        <label class="text-muted small fw-bold mb-1 text-uppercase">E-Posta Adresi</label>
                        <p class="fs-5 fw-medium text-dark mb-0">
                            <i class="bi bi-envelope text-primary me-2"></i> @Model.e_posta
                        </p>
                    </div>
                </div>
            </div>

            <div class="mt-4 text-end">
                <a href="/Admin/Duzenle/@Model.kullanici_id" class="btn btn-warning shadow-sm"><i class="bi bi-pencil-square"></i> Düzenle</a>
                <a href="/Admin/Sil/@Model.kullanici_id" class="btn btn-outline-danger ms-2 shadow-sm" onclick="return confirm('Bu personeli sistemden silmek istediğinize emin misiniz?');"><i class="bi bi-trash"></i> Sil</a>
            </div>
        </div>
    </div>
</div>






