@model IEnumerable<KcetasWeb.Models.Kullanici>

@{
    ViewData["Title"] = "Admin Paneli - Kullanıcılar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 text-danger fw-bold">Sistem Kullanıcıları</h2>
    <a href="/Admin/Yeni" class="btn btn-primary fw-bold">+ Yeni Personel Ekle</a>
</div>
@if (TempData["PersonelMesaji"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
        <strong>İşlem Başarılı!</strong> @TempData["PersonelMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Ad Soyad</th>
                        <th>Kullanıcı Adı</th>
                        <th>E-Posta</th>
                        <th>Rol</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- C#'tan gelen verileri döngüyle tabloya basıyoruz -->
                    @foreach (var personel in Model)
                    {
                        <tr>
                            <td><strong>#@personel.KullaniciId</strong></td>
                            <td>@personel.AdSoyad</td>
                            <td>@personel.KullaniciAdi</td>
                            <td>@personel.EPosta</td>
                            <td><span class="badge bg-secondary">@personel.Rol.RolAdi</span></td>
                            <td>
                                @if(personel.Durum == "AKTIF")
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pasif</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary">Düzenle</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>