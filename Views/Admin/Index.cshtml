@model List<KcetasWeb.Models.entities.Kullanici>

@{
    ViewData["Title"] = "Admin Paneli - Kullanıcılar";

    string RolEtiketi(string? rolAdi) => rolAdi switch
    {
        "Yonetici" => "Yönetici",
        "Kullanici" => "Personel",
        "Abone" => "Abone",
        _ => rolAdi ?? "Tanımsız"
    };

    string RolBadgeRengi(string? rolAdi) => rolAdi switch
    {
        "Yonetici" => "bg-danger",
        "Kullanici" => "bg-primary",
        "Abone" => "bg-info text-dark",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 text-danger fw-bold">Sistem Kullanıcıları</h2>
    <a href="/Admin/Yeni" class="btn btn-primary fw-bold">+ Yeni Personel Ekle</a>
</div>
@if (TempData["PersonelMesaji"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
        <strong>İşlem Başarılı!</strong> @TempData["PersonelMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Ad Soyad</th>
                        <th>Kullanıcı Adı</th>
                        <th>E-Posta</th>
                        <th>Rol</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var personel in Model)
                    {
                        <tr>
                            <td><strong>#@personel.kullanici_id</strong></td>
                            <td>@personel.ad_soyad</td>
                            <td>@personel.kullanici_adi</td>
                            <td>@personel.e_posta</td>
                            <td><span class="badge @RolBadgeRengi(personel.Rol?.rol_adi)">@RolEtiketi(personel.Rol?.rol_adi)</span></td>
                            <td>
                                @if (personel.durum == "AKTIF")
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pasif</span>
                                }
                            </td>
                            <td>
                                <a href="/Admin/Detay/@personel.kullanici_id" class="btn btn-sm btn-outline-primary shadow-sm">Detay</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>