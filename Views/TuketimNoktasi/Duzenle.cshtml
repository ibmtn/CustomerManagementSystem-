@model KcetasWeb.Models.TuketimNoktasi

@{
    ViewData["Title"] = "Tüketim Noktası Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="mb-3">
            <a href="/TuketimNoktasi/Detay/@Model.TuketimNoktasiNo" class="btn btn-sm btn-outline-secondary">&larr; Detaya Geri Dön</a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-warning text-dark py-3">
                <h5 class="card-title mb-0 fw-bold">Tüketim Noktası Bilgilerini Düzenle</h5>
            </div>
            <div class="card-body p-4">
                <form action="/TuketimNoktasi/Duzenle" method="post">
                    <input type="hidden" name="TuketimNoktasiNo" value="@Model.TuketimNoktasiNo" />
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Abone ID <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="AboneId" value="@Model.AboneId" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Sokak ID <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="SokakId" value="@Model.SokakId" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Bina No</label>
                            <input type="text" class="form-control" name="BinaNo" value="@Model.BinaNo" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Daire No</label>
                            <input type="text" class="form-control" name="DaireNo" value="@Model.DaireNo" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tüketici Grubu ID</label>
                            <input type="number" class="form-control" name="TuketiciGrubuId" value="@Model.TuketiciGrubuId" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tarife Tipi ID</label>
                            <input type="number" class="form-control" name="TarifeTipiId" value="@Model.TarifeTipiId" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold">Durum <span class="text-danger">*</span></label>
                            <select class="form-select" name="Durum" required>
                                <option value="Aktif" selected="@(Model.Durum == "Aktif")">Aktif</option>
                                <option value="Pasif" selected="@(Model.Durum == "Pasif")">Pasif</option>
                            </select>
                        </div>
                    </div>

                    <hr class="text-muted mb-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/TuketimNoktasi/Detay/@Model.TuketimNoktasiNo" class="btn btn-light border">İptal</a>
                        <button type="submit" class="btn btn-warning px-4 fw-bold shadow-sm">Değişiklikleri Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
