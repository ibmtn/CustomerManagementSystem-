@model IEnumerable<KcetasWeb.Models.TuketimNoktasi>

@{
    ViewData["Title"] = "Tüketim Noktaları";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="h4 text-success fw-bold">Tüketim Noktaları</h2>
    <a href="/TuketimNoktasi/Yeni" class="btn btn-success fw-bold">+ Yeni Ekle</a>
</div>

@if (TempData["BasariMesaji"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        @TempData["BasariMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Nokta No</th>
                        <th>Abone ID</th>
                        <th>Sokak ID</th>
                        <th>Bina / Daire</th>
                        <th>Grup / Tarife</th>
                        <th>Durum</th>
                        <th class="pe-4 text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4"><strong>@item.TuketimNoktasiNo</strong></td>
                            <td>@item.AboneId</td>
                            <td>@item.SokakId</td>
                            <td>@item.BinaNo / @item.DaireNo</td>
                            <td>@item.TuketiciGrubuId / @item.TarifeTipiId</td>
                            <td>
                                @if (item.Durum == "Aktif")
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@item.Durum</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <a href="/TuketimNoktasi/Detay/@item.TuketimNoktasiNo" class="btn btn-sm btn-light border text-primary shadow-sm">Detay</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
