@model IEnumerable<KcetasWeb.Models.TuketimNoktasi>

@{
    ViewData["Title"] = "Tüketim Noktaları ve Aboneler";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="h4 text-success fw-bold">Tüketim Noktaları ve Aboneler</h2>
    <a href="/TuketimNoktasi/Yeni" class="btn btn-success fw-bold">+ Yeni Ekle</a>
</div>

@if (TempData["BasariMesaji"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        @TempData["BasariMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Tekil Kod</th>
                        <th>baglantı gücü</th>
                        <th>İlçe</th>
                        <th>TCKN / VKN</th>
                        <th>Bina / Daire</th>
                        <th>Tüketici Grubu</th>
                        <th>Durum</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var tcMaskeli = !string.IsNullOrEmpty(item.tckn) && item.tckn.Length >= 4 ? "***" + item.tckn.Substring(item.tckn.Length - 4) : item.tckn;
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.tekil_kod</td>
                                <td>@item.BaglantiGucuKw</td>
                                <td>@item.ilce_adi</td>
                                
                                <td>
                                    <span class="badge bg-secondary">@tcMaskeli</span>
                                    @if(!string.IsNullOrEmpty(item.vkn)) { <span class="badge bg-info">VKN:@item.vkn</span> }
                                </td>
                                <td>@item.bina_no / @item.bagimsiz_bolum_no</td>
                                <td>@item.tuketici_grubu</td>
                                <td>
                                    <span class="badge bg-@(item.status == "Aktif" ? "success" : "danger")">
                                        @item.status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/TuketimNoktasi/Detay/@item.tekil_kod" class="btn btn-sm btn-outline-primary rounded-3 px-3">Detay</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Henüz kayıtlı tüketim noktası bulunmuyor.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
