@{
    ViewData["Title"] = "Tüketim Noktaları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 text-primary fw-bold">Tüketim Noktası Yönetimi</h2>
    <a href="/TuketimNoktasi/Yeni" class="btn btn-success fw-bold">+ Yeni Kayıt Ekle</a>
</div>

<!-- BAŞARI MESAJI BURAYA (EN ÜSTE) GELDİ -->
@if (TempData["BasariMesaji"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
        <strong>İşlem Başarılı!</strong> @TempData["BasariMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tekil Kod</th>
                        <th>Kullanım Sınıfı</th>
                        <th>Bağlantı Gücü (kW)</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>TK-2026-001</strong></td>
                        <td>Mesken</td>
                        <td>5.00</td>
                        <td><span class="badge bg-success">Aktif</span></td>
                        <td><button class="btn btn-sm btn-outline-primary">Detay</button></td>
                    </tr>
                    <tr>
                        <td><strong>TK-2026-002</strong></td>
                        <td>Ticarethane</td>
                        <td>15.50</td>
                        <td><span class="badge bg-warning text-dark">Bağlantı Bekliyor</span></td>
                        <td><button class="btn btn-sm btn-outline-primary">Detay</button></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>