@model IEnumerable<KcetasWeb.Models.TuketimNoktasi>

@{
    ViewData["Title"] = "Tüketim Noktaları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 text-primary fw-bold">Tüketim Noktası Yönetimi</h2>
    <a href="/TuketimNoktasi/Yeni" class="btn btn-success fw-bold">+ Yeni Kayıt Ekle</a>
</div>

<!-- BAŞARI MESAJI BURAYA (EN ÜSTE) GELDİ -->
@if (TempData["BasariMesaji"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
        <strong>İşlem Başarılı!</strong> @TempData["BasariMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tekil Kod</th>
                        <th>Kullanım Sınıfı</th>
                        <th>Bağlantı Gücü (kW)</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tn in Model)
                    {
                        <tr>
                            <td><strong>@tn.TekilKod</strong></td>
                            <td>@tn.TuketiciGrubu</td>
                            <td>@tn.BaglantiGucuKw.ToString("0.00")</td>
                            <td>
                                @if (tn.BaglantiDurumu == "Aktif")
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@tn.BaglantiDurumu</span>
                                }
                            </td>
                            <td><a href="/TuketimNoktasi/Detay/@tn.TekilKod" class="btn btn-sm btn-outline-primary shadow-sm">Detay</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
