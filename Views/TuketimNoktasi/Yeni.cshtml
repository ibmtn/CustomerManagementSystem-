@{
    ViewData["Title"] = "Yeni Tüketim Noktası";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="mb-3">
            <a href="/TuketimNoktasi" class="btn btn-sm btn-outline-secondary">&larr; Listeye Geri Dön</a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white py-3">
                <h5 class="card-title mb-0 fw-bold">Yeni Tüketim Noktası Ekle</h5>
            </div>
            <div class="card-body p-4">
                <form action="/TuketimNoktasi/Yeni" method="post">
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Abone ID <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="AboneId" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Sokak ID <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="SokakId" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Bina No</label>
                            <input type="text" class="form-control" name="BinaNo" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Daire No</label>
                            <input type="text" class="form-control" name="DaireNo" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tüketici Grubu ID <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="TuketiciGrubuId" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tarife Tipi ID <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="TarifeTipiId" required />
                        </div>
                    </div>

                    <hr class="text-muted mb-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/TuketimNoktasi" class="btn btn-light border">İptal</a>
                        <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm">Noktayı Oluştur</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>