@{
    ViewData["Title"] = "Yeni Tüketim Noktası";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="mb-3">
            <a href="/TuketimNoktasi" class="btn btn-sm btn-outline-secondary">&larr; Listeye Geri Dön</a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="card-title mb-0 fw-bold">Yeni Tüketim Noktası Kayıt Formu</h5>
            </div>
            <div class="card-body p-4">
                <form action="/TuketimNoktasi/Yeni" method="post">
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted">Tekil Kod (Sistem Üretecek)</label>
                        <!-- name="TekilKod" eklendi -->
                        <input type="text" class="form-control bg-light" name="TekilKod" value="TK-@DateTime.Now.ToString("yyyyMMdd")-XXXX" readonly />
                        <div class="form-text">Her tüketim noktası için benzersiz bir kod atanır.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tüketici Grubu <span class="text-danger">*</span></label>
                            <!-- name="TuketiciGrubu" eklendi -->
                            <select class="form-select" name="TuketiciGrubu" required>
                                <option value="">-- Seçiniz --</option>
                                <option value="Mesken">Mesken (Ev)</option>
                                <option value="Ticarethane">Ticarethane (İş Yeri)</option>
                                <option value="Sanayi">Sanayi</option>
                                <option value="Tarımsal Sulama">Tarımsal Sulama</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Bağlantı Gücü (kW) <span class="text-danger">*</span></label>
                            <!-- name="BaglantiGucu" eklendi -->
                            <input type="number" step="0.01" min="0.01" class="form-control" name="BaglantiGucu" placeholder="Örn: 5.00" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Açık Adres <span class="text-danger">*</span></label>
                        <!-- name="AcikAdres" eklendi -->
                        <textarea class="form-control" rows="3" name="AcikAdres" placeholder="Açık adresi detaylı yazınız..." required></textarea>
                    </div>

                    <hr class="text-muted my-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/TuketimNoktasi" class="btn btn-light border">İptal</a>
                        <button type="submit" class="btn btn-success px-4">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>