@model KcetasWeb.Models.TuketimNoktasi

@{
    ViewData["Title"] = "Tüketim Noktası Detayı";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 text-success fw-bold">
            <i class="bi bi-geo-alt-fill me-2"></i> Tüketim Noktası Detayı
        </h2>
        <a href="/TuketimNoktasi/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Listeye Dön
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-gradient bg-success text-white p-4">
            <div class="d-flex align-items-center">
                <div class="bg-white text-success rounded-circle d-flex justify-content-center align-items-center shadow-sm" style="width: 60px; height: 60px; font-size: 24px;">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <div class="ms-3">
                    <h3 class="mb-0 fw-bold">@Model.TuketimNoktasiNo</h3>
                    <p class="mb-0 opacity-75">Abone ID: @Model.AboneId</p>
                </div>
                <div class="ms-auto">
                    @if (Model.Durum == "Aktif")
                    {
                        <span class="badge bg-light text-success rounded-pill px-3 py-2 fs-6 shadow-sm"><i class="bi bi-check-circle-fill me-1"></i> Aktif</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2 fs-6 shadow-sm"><i class="bi bi-exclamation-triangle-fill me-1"></i> @Model.Durum</span>
                    }
                </div>
            </div>
        </div>
        <div class="card-body p-4 bg-light">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="p-3 bg-white rounded-3 shadow-sm border border-light h-100">
                        <label class="text-muted small fw-bold mb-1 text-uppercase"><i class="bi bi-geo-alt me-1"></i> Sokak ID / Bina No</label>
                        <p class="fs-4 fw-bold text-dark mb-0">@Model.SokakId / @Model.BinaNo</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 bg-white rounded-3 shadow-sm border border-light h-100">
                        <label class="text-muted small fw-bold mb-1 text-uppercase"><i class="bi bi-calendar-plus me-1"></i> Kayıt Tarihi</label>
                        <p class="fs-5 fw-medium text-dark mb-0">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="p-3 bg-white rounded-3 shadow-sm border border-light h-100">
                        <label class="text-muted small fw-bold mb-1 text-uppercase"><i class="bi bi-diagram-3 me-1"></i> Tüketici Grubu / Tarife Tipi</label>
                        <p class="fs-5 fw-medium text-dark mb-0">Grup ID: @Model.TuketiciGrubuId | Tarife ID: @Model.TarifeTipiId</p>
                    </div>
                </div>
            </div>

            <div class="mt-4 text-end">
                <a href="/TuketimNoktasi/Duzenle/@Model.TuketimNoktasiNo" class="btn btn-warning shadow-sm"><i class="bi bi-pencil-square"></i> Düzenle</a>
            </div>
        </div>
    </div>
</div>
