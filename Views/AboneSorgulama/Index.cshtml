@model List<KcetasWeb.Models.Abone>

@{
    ViewData["Title"] = "Abone Sorgulama";
}

<div class="container-fluid mt-3">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-0 text-gray-800 fw-bold">
                <i class="bi bi-search text-primary me-2"></i> Abone Sorgulama
            </h2>
            <p class="text-muted mt-1 mb-0">Sistemde kayıtlı aboneleri TCKN, VKN, Abone No veya İsim ile arayın.</p>
        </div>
    </div>

    <!-- Search Card -->
    <div class="card shadow-sm border-0 mb-4 rounded-4">
        <div class="card-body p-4 bg-light rounded-4">
            <form action="/AboneSorgulama/Index" method="get">
                <div class="row g-3 align-items-center">
                    <div class="col-md-10">
                        <div class="input-group input-group-lg shadow-sm rounded-3">
                            <span class="input-group-text bg-white border-end-0 text-primary">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" class="form-control border-start-0 ps-0" 
                                   name="q" 
                                   placeholder="TCKN / VKN, Abone No veya Ad Soyad giriniz..." 
                                   value="@ViewBag.Query" 
                                   autocomplete="off" />
                        </div>
                    </div>
                    <div class="col-md-2 d-grid">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm rounded-3 fw-bold">
                            Sorgula
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Section -->
    @if (Model != null)
    {
        if (Model.Count == 0)
        {
            <div class="alert alert-warning shadow-sm border-0 d-flex align-items-center rounded-3 p-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>
                <div>
                    <h5 class="alert-heading fw-bold mb-1">Kayıt Bulunamadı</h5>
                    <p class="mb-0">"<strong>@ViewBag.Query</strong>" aramasına uygun herhangi bir abone sistemde bulunamadı. Lütfen arama kriterlerinizi kontrol edip tekrar deneyin.</p>
                </div>
            </div>
        }
        else
        {
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-white py-3 d-flex align-items-center border-bottom-0">
                    <h6 class="m-0 font-weight-bold text-success">
                        <i class="bi bi-check-circle-fill me-2"></i> @Model.Count Kayıt Bulundu
                    </h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Abone No</th>
                                    <th>Ad Soyad / Unvan</th>
                                    <th>TCKN / VKN</th>
                                    <th>Tip</th>
                                    <th>Durum</th>
                                    <th class="text-end pe-4">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var abone in Model)
                                {
                                    <tr>
                                        <td class="ps-4"><strong>@abone.AboneNo</strong></td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                                    <i class="bi bi-person-fill"></i>
                                                </div>
                                                <div>
                                                    <h6 class="mb-0 fw-bold">@abone.Ad @abone.Soyad</h6>
                                                    <small class="text-muted"><i class="bi bi-telephone-fill me-1"></i> @abone.Telefon</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="font-monospace text-muted">@abone.TcKimlikNo</span></td>
                                        <td>
                                            <span class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill px-3">Bireysel</span>
                                        </td>
                                        <td>
                                            @if(abone.Durum == "Aktif")
                                            {
                                                <span class="badge bg-success rounded-pill px-3">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger rounded-pill px-3">Pasif</span>
                                            }
                                        </td>
                                        <td class="text-end pe-4">
                                            <a href="/AboneSorgulama/Detay/@abone.AboneId" class="btn btn-sm btn-outline-primary shadow-sm rounded-pill px-3">Detay Görüntüle</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>
