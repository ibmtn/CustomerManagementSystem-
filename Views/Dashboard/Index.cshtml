@{
    ViewData["Title"] = "Ana Sayfa";
}
<div class="text-center mb-5 mt-4">
    <img src="wwwroot/images/logo.png"
         class="kcetas-logo"
         alt="KCETAŞ Logo"/>
    <h1 class="display-5 fw-bold text-primary">KCETAŞ BİLGİ PORTALINA HOŞGELDİNİZ</h1>
    <p class="lead text-muted">Sistem genel özetini ve aktif istatistikleri aşağıdan inceleyebilirsiniz.</p>
</div>
<div class="alert alert-light border shadow-sm rounded-4 mb-4">
    <h5 class="fw-bold mb-2">
        📌 Sistem Hakkında
    </h5>

    <p class="mb-0">
        Bu portal üzerinden tüketim noktaları, sözleşmeler, abonelik bilgileri ve
        iş süreçlerine ait genel istatistikleri görüntüleyebilirsiniz.
    </p>
</div>
<!-- 3'lü İstatistik Kartları -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card bg-primary text-white shadow-sm border-0 h-100 rounded-4">
            <div class="card-body text-center p-4">
               <i class="bi bi-lightning-charge-fill fs-1 mb-3"></i> <h5 class="card-title fw-light mb-3">Toplam Tüketim Noktası</h5>
               <style>background-color: #005AA9;</style>
                <h2 class="display-4 fw-bold mb-0">1,248</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white shadow-sm border-0 h-100 rounded-4">
            <div class="card-body text-center p-4"> 
              <i class="bi bi-file-earmark-text-fill fs-1 mb-3"></i>  <h5 class="card-title fw-light mb-3">Aktif Sözleşmeler</h5>
              <style>background-color: #F7B500;</style>

                <h2 class="display-4 fw-bold mb-0">856</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-warning text-dark shadow-sm border-0 h-100 rounded-4">
            <div class="card-body text-center p-4">
                <i class="bi bi-hourglass-split fs-1 mb-3"></i><h5 class="card-title fw-light mb-3">Bekleyen İşlemler</h5>
                <style>background-color: #FFFFFF;</style>
                <h2 class="display-4 fw-bold mb-0">24</h2>
            </div>
            </div>
</div>
        </div>
    </div>
</div>
<div class="row mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm rounded-4">
            <div class="card-body">
                <h5>📢 Duyurular</h5>
                <ul class="mb-0">
                    <li>Sistem güncellemeleri burada yayınlanacaktır.</li>
                    <li>Yeni özellikler bu alandan takip edilebilir.</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm rounded-4">
            <div class="card-body">
                <h5>ℹ️ Bilgilendirme</h5>
                <p class="mb-0">
                    Sol menü üzerinden sistem modüllerine erişebilirsiniz.
                </p>
            </div>
        </div>
    </div>
</div>
