@{
    ViewData["Title"] = "Gösterge Paneli (Dashboard)";
    var sonKullanicilar = ViewBag.SonKullanicilar as List<KcetasWeb.Models.entities.Kullanici>;
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <div>
        <h2 class="h3 text-primary fw-bold mb-0">Yönetici Gösterge Paneli</h2>
        <p class="text-muted mb-0">Sistemin genel durumunu ve kritik göstergeleri takip edin.</p>
    </div>
    <div>
        <p class="text-muted fw-bold mb-0">Tarih: @DateTime.Now.ToString("dd MMMM yyyy, dddd")</p>
    </div>
</div>

<!-- ÜST BİLGİ KARTLARI -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card bg-white shadow-sm border-0 rounded-4 border-start border-5 border-primary h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted fw-bold mb-1">Toplam Kullanıcı</h6>
                        <h3 class="mb-0 fw-bold text-dark">@ViewBag.ToplamKullanici</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3">
                        <i class="bi bi-people-fill text-primary fs-3"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted small">
                    <span class="text-success fw-bold">@ViewBag.AktifKullanici Aktif</span> personel hesabı
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card bg-white shadow-sm border-0 rounded-4 border-start border-5 border-info h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted fw-bold mb-1">Kayıtlı Tüketim Noktası</h6>
                        <h3 class="mb-0 fw-bold text-dark">@ViewBag.AktifTuketimNoktasi</h3>
                    </div>
                    <div class="bg-info bg-opacity-10 p-3 rounded-3">
                        <i class="bi bi-geo-alt-fill text-info fs-3"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted small">
                    Sistemdeki toplam tüketim noktası
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-white shadow-sm border-0 rounded-4 border-start border-5 border-warning h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted fw-bold mb-1">Bekleyen Outbox</h6>
                        <h3 class="mb-0 fw-bold text-dark">@ViewBag.OutboxBekleyen</h3>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-3 rounded-3">
                        <i class="bi bi-hourglass-split text-warning fs-3"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted small">
                    Entegrasyon kuyruğunda bekleyen
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-white shadow-sm border-0 rounded-4 border-start border-5 border-danger h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted fw-bold mb-1">Hatalı Outbox İşlemi</h6>
                        <h3 class="mb-0 fw-bold text-dark">@ViewBag.OutboxHatali</h3>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-3 rounded-3">
                        <i class="bi bi-exclamation-triangle-fill text-danger fs-3"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted small">
                    <a asp-controller="Outbox" asp-action="Index" class="text-danger fw-bold text-decoration-none">Detayları İncele <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- SON EKLENEN KULLANICILAR -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0 text-dark">Son Eklenen Kullanıcılar</h5>
                <a asp-controller="Admin" asp-action="Index" class="btn btn-sm btn-outline-primary">Tümünü Gör</a>
            </div>
            <div class="card-body">
                @if (sonKullanicilar != null && sonKullanicilar.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var user in sonKullanicilar)
                        {
                            <div class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center border-bottom-0">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 rounded-circle p-2 me-3 text-primary fw-bold" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                                        @user.ad_soyad.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-dark">@user.ad_soyad</h6>
                                        <small class="text-muted">@user.e_posta</small>
                                    </div>
                                </div>
                                <div>
                                    <span class="badge bg-light text-dark border">@user.durum</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">Sistemde henüz kayıtlı kullanıcı bulunmuyor.</p>
                }
            </div>
        </div>
    </div>

    <!-- HIZLI İŞLEMLER -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4 h-100 bg-light">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4 text-dark">Hızlı İşlemler</h5>
                
                <div class="d-grid gap-3">
                    <a asp-controller="Admin" asp-action="Yeni" class="btn btn-white shadow-sm border text-start p-3 fw-bold text-dark rounded-3 d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 p-2 rounded me-3">
                            <i class="bi bi-person-plus text-primary fs-5"></i>
                        </div>
                        <div>
                            Sisteme Yeni Personel Ekle
                            <div class="text-muted small fw-normal">Yetkili bir personel veya abone hesabı oluşturun.</div>
                        </div>
                    </a>
                    
                    <a asp-controller="Fatura" asp-action="Olustur" class="btn btn-white shadow-sm border text-start p-3 fw-bold text-dark rounded-3 d-flex align-items-center">
                        <div class="bg-success bg-opacity-10 p-2 rounded me-3">
                            <i class="bi bi-receipt text-success fs-5"></i>
                        </div>
                        <div>
                            Manuel Fatura Oluştur
                            <div class="text-muted small fw-normal">Sistem dışı yeni bir fatura kaydı girin.</div>
                        </div>
                    </a>
                    
                    <a asp-controller="Outbox" asp-action="Index" class="btn btn-white shadow-sm border text-start p-3 fw-bold text-dark rounded-3 d-flex align-items-center">
                        <div class="bg-warning bg-opacity-10 p-2 rounded me-3">
                            <i class="bi bi-arrow-repeat text-warning fs-5"></i>
                        </div>
                        <div>
                            Hatalı Entegrasyonları Yeniden Dene
                            <div class="text-muted small fw-normal">Gönderilemeyen outbox kayıtlarını yönetin.</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
