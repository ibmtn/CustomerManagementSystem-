@model KcetasWeb.ViewModels.IsEmriListeViewModel
@using KcetasWeb.Models.enums

@{
    ViewData["Title"] = "İş Emri Listesi";
    var tipSecenekleri = Html.GetEnumSelectList<IsEmriTipi>();
    var durumSecenekleri = Html.GetEnumSelectList<IsEmriDurumu>();
}

@if (TempData["Mesaj"] != null)
{
    <div class="alert alert-@(TempData["MesajTip"] ?? "info") alert-dismissible fade show" role="alert">
        @TempData["Mesaj"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="fw-bold text-dark mb-0">İş Emri Listesi</h3>
    <span class="badge bg-secondary bg-opacity-10 text-secondary border fs-6">
        Toplam: @Model.IsEmirleri.Count
    </span>
</div>

<!-- ── Filtre Formu ── -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label">Tip</label>
                <select asp-for="FiltreTip" asp-items="tipSecenekleri" class="form-select">
                    <option value="">Tümü</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Durum</label>
                <select asp-for="FiltreDurum" asp-items="durumSecenekleri" class="form-select">
                    <option value="">Tümü</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Başlangıç Tarihi</label>
                <input asp-for="BaslangicTarih" type="date" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Bitiş Tarihi</label>
                <input asp-for="BitisTarih" type="date" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Ara</label>
                <input asp-for="AramaMetni" type="text" class="form-control" placeholder="İş emri no, adres..." />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-search"></i> Filtrele
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- ── Liste Tablosu ── -->
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (!Model.IsEmirleri.Any())
        {
            <div class="text-center text-muted py-5">
                <p class="mb-0">Kayıt bulunamadı.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>İş Emri No</th>
                            <th>Tip</th>
                            <th>Durum</th>
                            <th>Tüketim Noktası</th>
                            <th>Planlanan Tarih</th>
                            <th>Atanan Kullanıcı</th>
                            <th>Adres</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach  (var item in Model.IsEmirleri)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    <a asp-action="Detay" asp-route-id="@item.IsEmriId" class="text-decoration-none">
                                        @item.IsEmriNo
                                    </a>
                                </td>
                                <td>
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info">
                                        @item.TipAdi
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-@item.DurumRenk">@item.DurumAdi</span>
                                </td>
                                <td>@item.TuketimNoktasiKodu</td>
                                <td>@item.PlanlananTarih.ToString("dd.MM.yyyy")</td>
                                <td>@item.AtananKullaniciAdi</td>
                                <td class="text-truncate" style="max-width: 220px;" title="@item.Adres">
                                    @item.Adres
                                </td>
                                <td class="text-end">
                                    <a asp-action="Detay" asp-route-id="@item.IsEmriId" class="btn btn-sm btn-outline-secondary">
                                        Detay
                                    </a>
                                    @if (item.Durum != IsEmriDurumu.Tamamlandi && item.Durum != IsEmriDurumu.IptalEdildi)
                                    {
                                        <a asp-action="TutanakGiris" asp-route-id="@item.IsEmriId" class="btn btn-sm btn-success">
                                            Tutanak Gir
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>