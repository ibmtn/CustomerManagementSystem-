@model KcetasWeb.ViewModels.IsEmriListeViewModel

@{
    ViewData["Title"] = "İş Emri Listesi";
    var tipSecenekleri = new List<SelectListItem> { 
        new SelectListItem("Sayaç Bağlama", "Sayaç Bağlama"), 
        new SelectListItem("Sayaç Değiştirme", "Sayaç Değiştirme"), 
        new SelectListItem("Sayaç Sökme", "Sayaç Sökme"), 
        new SelectListItem("Enerji Kesme", "Enerji Kesme"), 
        new SelectListItem("Enerji Açma", "Enerji Açma") 
    };
    var durumSecenekleri = new List<SelectListItem> { new SelectListItem("Oluşturuldu", "Oluşturuldu"), new SelectListItem("Ekibe Atandı", "Ekibe Atandı"), new SelectListItem("Devam Ediyor", "Devam Ediyor"), new SelectListItem("Tamamlandı", "Tamamlandı") };
}

@if (TempData["Mesaj"] != null)
{
    <div class="alert alert-@(TempData["MesajTip"] ?? "info") alert-dismissible fade show" role="alert">
        @TempData["Mesaj"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="fw-bold text-dark mb-0">İş Emri Listesi</h3>
    <span class="badge bg-secondary bg-opacity-10 text-secondary border fs-6">
        Toplam: @Model.IsEmirleri.Count
    </span>
</div>

<!-- ── Filtre Formu ── -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <!-- 1. Satır: Yeni Eklenen Filtreler -->
            <div class="col-md-2">
                <label class="form-label">İş Emri No</label>
                <input asp-for="FiltreIsEmriNo" type="text" class="form-control" placeholder="Örn: IE-2026-001"/>
            </div>
            <div class="col-md-2">
                <label class="form-label">Tekil Kod</label>
                <input asp-for="FiltreTekilKod" type="text" class="form-control" placeholder="Örn: TK-2026-001" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Abone Adı / Ünvanı</label>
                <input asp-for="FiltreAboneAdi" type="text" class="form-control" placeholder="İsim veya Ünvan"/>
            </div>
            <div class="col-md-3">
                <label class="form-label">Atanan Personel</label>
                <input asp-for="FiltrePersonel" type="text" class="form-control" placeholder="Personel Adı" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Öncelik</label>
                <select asp-for="FiltreOncelik" class="form-select">
                    <option value="">Tümü</option>
                    <option value="Yüksek">Yüksek</option>
                    <option value="Normal">Normal</option>
                    <option value="Düşük">Düşük</option>
                </select>
            </div>

            <!-- 2. Satır: Mevcut Filtreler -->
            <div class="col-md-2">
                <label class="form-label">Tip</label>
                <select asp-for="FiltreTip" asp-items="tipSecenekleri" class="form-select">
                    <option value="">Tümü</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Durum</label>
                <select asp-for="FiltreDurum" asp-items="durumSecenekleri" class="form-select">
                    <option value="">Tümü</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Başlangıç Tarihi</label>
                <input asp-for="BaslangicTarih" type="date" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Bitiş Tarihi</label>
                <input asp-for="BitisTarih" type="date" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Genel Ara</label>
                <input asp-for="AramaMetni" type="text" class="form-control" placeholder="Genel arama..." />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-search"></i> Filtrele
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary" title="Filtreleri Temizle">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- ── Liste Tablosu ── -->
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (!Model.IsEmirleri.Any())
        {
            <div class="text-center text-muted py-5">
                <p class="mb-0">Kayıt bulunamadı.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>İş Emri No</th>
                            <th>Tip</th>
                            <th>Durum</th>
                            <th>Abone</th>
                            <th>Öncelik Durumu</th>
                            <th>Tüketim Noktası & Adres</th>
                            <th>Planlanan Tarih</th>
                            <th>Oluşturulma Tarihi</th>
                            <th>Atanan Kullanıcı</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach  (var item in Model.IsEmirleri)
                        {
                            <tr>
                                <td class="py-3 fw-bold">
                                    @item.IsEmriNo
                                </td>
                                <td>
                                    <span class="text-secondary fw-medium">@item.Tip</span>
                                </td>
                                <td>
                                    <span class="badge bg-@item.DurumRenk px-2 py-1">@item.Durum</span>
                                </td>
                                <td>
                                    <span class="text-secondary fw-medium">@item.musteriDurum</span>
                                </td>
                                <td>
                                    <span>@item.oncelik</span>
                                </td>
                                <td>
                                    <span class="text-dark fw-medium"><i class="bi bi-geo-alt-fill text-muted"></i> @item.tekil_kod</span><br />
                                    <small class="text-muted">@item.Adres</small>
                                </td>
                                <td>@(item.PlanlananTarih?.ToString("dd.MM.yyyy") ?? "-")</td>
                                <td>
                                    <span>
                                        @item.CreatedAt
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-2" style="width: 28px; height: 28px; font-size: 12px;">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <span>@item.AtananKullaniciAdi</span>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Detay" asp-route-id="@item.IsEmriId" class="btn btn-sm btn-outline-secondary">
                                        Detay
                                    </a>
                                    @if (item.Durum != "Tamamlandı" && item.Durum != "İptal Edildi")
                                    {
                                        <a asp-action="TutanakGiris" asp-route-id="@item.IsEmriId" class="btn btn-sm btn-success">
                                            Tutanak Gir
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>