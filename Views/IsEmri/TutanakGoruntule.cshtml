@model KcetasWeb.ViewModels.IsEmriDetayViewModel
@{
    ViewData["Title"] = "Tutanak Görüntüle - " + Model.TutanakNo;
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap CSS for styling the PDF layout -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- html2pdf.js for generating PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        body { background-color: #f8f9fa; }
        .a4-container {
            width: 210mm;
            min-height: 297mm;
            margin: 20px auto;
            background: #fff;
            padding: 20mm;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        .header-logo { max-height: 80px; }
        .section-title {
            border-bottom: 2px solid #0056b3;
            color: #0056b3;
            font-weight: bold;
            padding-bottom: 5px;
            margin-top: 20px;
            margin-bottom: 15px;
        }
        .info-table th { width: 30%; background-color: #f8f9fa; }
        
        /* Butonları yazdırma esnasında gizlemek için */
        @@media print {
            .no-print { display: none !important; }
            .a4-container { margin: 0; box-shadow: none; width: 100%; }
            body { background-color: #fff; }
        }
    </style>
</head>
<body>

    <div class="text-center mt-3 no-print">
        <a href="/IsEmri/Detay/@Model.IsEmriId" class="btn btn-secondary me-2">Geri Dön</a>
        <button onclick="window.print()" class="btn btn-primary me-2">Yazdır</button>
        <button onclick="downloadPDF()" class="btn btn-success">PDF Olarak İndir</button>
    </div>

    <!-- Bu div içeriği PDF'e dönüştürülecektir -->
    <div id="pdf-content" class="a4-container">
        
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
            <div>
                <!-- Logoyu wwwroot/images klasöründen okuyoruz -->
                <img src="/images/logo.png" alt="KCETAŞ Logo" class="header-logo" onerror="this.src='https://via.placeholder.com/150x80?text=Logo+Bulunamadi';">
            </div>
            <div class="text-end">
                <h4 class="fw-bold mb-1">SAHA OPERASYON TUTANAĞI</h4>
                <div class="text-muted">Tarih: @Model.UpdatedAt?.ToString("dd.MM.yyyy HH:mm")</div>
                <div class="text-muted">Tutanak No: @Model.TutanakNo</div>
            </div>
        </div>

        <h5 class="section-title">İş Emri Bilgileri</h5>
        <table class="table table-bordered info-table">
            <tbody>
                <tr>
                    <th>İş Emri No</th>
                    <td>@Model.IsEmriNo</td>
                </tr>
                <tr>
                    <th>İşlem Tipi</th>
                    <td>@Model.Tip</td>
                </tr>
                <tr>
                    <th>Durum</th>
                    <td>@Model.Durum</td>
                </tr>
                <tr>
                    <th>Planlanan Tarih</th>
                    <td><p class="fw-bold mb-0">@(Model.PlanlananTarih?.ToString("dd.MM.yyyy") ?? "Belirtilmedi")</p></td>
                </tr>
            </tbody>
        </table>

        @if (Model.IsSokmeTakma)
        {
            <h5 class="section-title">Sayaç Değişim & Endeks Bilgileri</h5>
            <table class="table table-bordered info-table">
                <tbody>
                    <tr>
                        <th>Eski Sayaç No</th>
                        <td>@Model.EskiSayacNo</td>
                    </tr>
                    <tr>
                        <th>Eski Sayaç Son Endeksi</th>
                        <td>@Model.EskiSonEndeksi</td>
                    </tr>
                    <tr>
                        <th>Yeni Sayaç No</th>
                        <td>@Model.YeniSayacNo</td>
                    </tr>
                    <tr>
                        <th>Yeni Sayaç İlk Endeksi</th>
                        <td>@Model.YeniIlkEndeksi</td>
                    </tr>
                </tbody>
            </table>
        }

        <h5 class="section-title">Saha Sonucu & Notlar</h5>
        <div class="p-3 bg-light border rounded mb-3">
            <strong>Yapılan İşlem:</strong><br />
            @Model.SahaSonucu
        </div>
        
        @if (!string.IsNullOrEmpty(Model.Gerekce))
        {
            <div class="p-3 bg-light border rounded mb-3">
                <strong>Gerekçe / Ek Açıklama:</strong><br />
                @Model.Gerekce
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.MuhurNo))
        {
            <div class="alert alert-info">
                <strong>Tatbik Edilen Mühür No:</strong> @Model.MuhurNo
            </div>
        }

        <div class="row mt-5 pt-5 text-center">
            <div class="col-6">
                <strong>Saha Görevlisi</strong><br />
                (İmza)
            </div>
            <div class="col-6">
                <strong>Müşteri / Abone</strong><br />
                (İmza)
            </div>
        </div>
    </div>

    <script>
        function downloadPDF() {
            const element = document.getElementById('pdf-content');
            
            // Konfigürasyon
            var opt = {
              margin:       [10, 10, 10, 10], // top, left, bottom, right
              filename:     'Tutanak_@Model.TutanakNo' + '.pdf',
              image:        { type: 'jpeg', quality: 0.98 },
              html2canvas:  { scale: 2, useCORS: true },
              jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            // HTML öğesini PDF'e dönüştür
            html2pdf().set(opt).from(element).save();
        }
    </script>
</body>
</html>
