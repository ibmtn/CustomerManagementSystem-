@model KcetasWeb.ViewModels.IsEmriDetayViewModel
@{
    ViewData["Title"] = "İş Emri Detay - " + Model.IsEmriNo;
}

@if (TempData["Mesaj"] != null)
{
    <div class="alert alert-@(TempData["MesajTip"] ?? "info") alert-dismissible fade show" role="alert">
        @TempData["Mesaj"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-3">
    <a href="/IsEmri" class="btn btn-sm btn-outline-secondary">&larr; İş Emirleri Listesine Dön</a>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h3 class="fw-bold text-dark mb-1">@Model.IsEmriNo</h3>
                <p class="fs-6 fw-bold text-dark mb-0">@(Model.PlanlananTarih.HasValue ? Model.PlanlananTarih.Value.ToString("dd.MM.yyyy") : "Planlanmadı")</p>
                <span class="badge bg-info bg-opacity-10 text-info border border-info me-1">@Model.Tip</span>
                <span class="badge bg-@Model.DurumRenk me-1">@Model.Durum</span>
                <span class="badge bg-secondary bg-opacity-10 text-secondary border">@Model.Oncelik</span>
            </div>
            <div>
            @if (Model.Durum != "Tamamlandı" && Model.Durum != "İptal Edildi")
            {
                <a href="/IsEmri/TutanakGiris/@Model.IsEmriId" class="btn btn-success">Tutanak Gir</a>
            }
            @if (Model.TutanakGirildiMi)
            {
                <a href="/IsEmri/TutanakGoruntule/@Model.IsEmriId" class="btn btn-outline-primary ms-2" target="_blank">
                    <i class="bi bi-eye"></i> Tutanak Görüntüle
                </a>
                <button onclick="window.print()" class="btn btn-primary ms-2">
                    <i class="bi bi-download"></i> İndir
                </button>
            }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Genel Bilgiler -->
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light border-0"><h6 class="fw-bold mb-0">Genel Bilgiler</h6></div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr><td class="text-muted fw-semibold" style="width:40%">İş Emri No</td><td><strong>@(Model.IsEmriNo ?? "-")</strong></td></tr>
                    <tr><td class="text-muted fw-semibold">Tip</td><td>@(Model.Tip ?? "-")</td></tr>
                    <tr><td class="text-muted fw-semibold">Durum</td><td>@(Model.Durum ?? "-")</td></tr>
                    <tr><td class="text-muted fw-semibold">Öncelik</td><td>@(Model.Oncelik ?? "-")</td></tr>
                </table>
            </div>
        </div>
    </div>
    <!-- Tüketim Noktası Bilgileri -->
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light border-0"><h6 class="fw-bold mb-0">Tüketim Noktası Bilgileri</h6></div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr><td class="text-muted fw-semibold" style="width:40%">Tüketim Noktası</td><td><strong>@(Model.TuketimNoktasiKodu ?? "-")</strong></td></tr>
                    <tr><td class="text-muted fw-semibold">Adres</td><td>@(Model.Adres ?? "-")</td></tr>
                </table>
            </div>
        </div>
    </div>
    <!-- Abone Bilgisi -->
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light border-0"><h6 class="fw-bold mb-0">Abone Bilgisi</h6></div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr><td class="text-muted fw-semibold" style="width:40%">Ad Soyad / Ünvan</td><td><strong>@(Model.musteriDurum ?? "-")</strong></td></tr>
                    <tr><td class="text-muted fw-semibold">Telefon</td><td>@(Model.telefon ?? "-")</td></tr>
                </table>
            </div>
        </div>
    </div>
    <!-- Sayaç Bilgisi -->
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light border-0"><h6 class="fw-bold mb-0">Sayaç Bilgisi</h6></div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr><td class="text-muted fw-semibold" style="width:40%">Seri No</td><td><strong>@(Model.SayacSeriNo ?? "-")</strong></td></tr>
                    <tr><td class="text-muted fw-semibold">Marka / Model</td><td>@(Model.marka ?? "-") / @(Model.model ?? "-")</td></tr>
                    <tr><td class="text-muted fw-semibold">Çarpan</td><td>@(Model.carpan.ToString() ?? "-")</td></tr>
                </table>
            </div>
        </div>
    </div>
    <!-- Atama & Zamanlama -->
    <div class="col-md-12 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light border-0"><h6 class="fw-bold mb-0">Atama & Zamanlama</h6></div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted fw-semibold" style="width:20%">Planlanan Tarih</td><td><strong>@(Model.PlanlananTarih.HasValue ? Model.PlanlananTarih.Value.ToString("dd.MM.yyyy") : "Planlanmadı")</strong></td>
                        <td class="text-muted fw-semibold" style="width:20%">Atanan Personel</td><td>@(Model.AtananKullaniciAdi ?? "Henüz atanmadı")</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Oluşturulma</td><td class="small">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-muted fw-semibold">Son Güncelleme</td><td class="small">@(Model.UpdatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

@if (Model.TutanakGirildiMi)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-success bg-opacity-10 border-0">
            <h6 class="fw-bold mb-0 text-success">Tutanak Bilgileri - @Model.TutanakNo</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless mb-0">
                        <tr><td class="text-muted fw-semibold" style="width:40%">Saha Sonucu</td><td><strong>@Model.SahaSonucu</strong></td></tr>
                        @if (!string.IsNullOrEmpty(Model.Gerekce))
                        {
                            <tr><td class="text-muted fw-semibold">Gerekçe</td><td>@Model.Gerekce</td></tr>
                        }
                    </table>
                </div>
                @if (Model.IsSokmeTakma)
                {
                    <div class="col-md-6">
                        <table class="table table-borderless mb-0">
                            <tr><td class="text-muted fw-semibold">Mühür No</td><td>@(Model.MuhurNo ?? "-")</td></tr>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}
else if (Model.Durum != "Tamamlandı" && Model.Durum != "İptal Edildi")
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body text-center py-4">
            <p class="text-muted mb-3">Bu iş emri için henüz tutanak girilmemiştir.</p>
            <a href="/IsEmri/TutanakGiris/@Model.IsEmriId" class="btn btn-success">Tutanak Gir</a>
        </div>
    </div>
}
