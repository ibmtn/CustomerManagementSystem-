@model KcetasWeb.ViewModels.IsEmriDetayViewModel
@{
    ViewData["Title"] = "İş Emri Detay - " + Model.IsEmriNo;
}

@if (TempData["Mesaj"] != null)
{
    <div class="alert alert-@(TempData["MesajTip"] ?? "info") alert-dismissible fade show" role="alert">
        @TempData["Mesaj"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-3">
    <a href="/IsEmri" class="btn btn-sm btn-outline-secondary">&larr; İş Emirleri Listesine Dön</a>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h3 class="fw-bold text-dark mb-1">@Model.IsEmriNo</h3>
                <span class="badge bg-info bg-opacity-10 text-info border border-info me-1">@Model.TipAdi</span>
                <span class="badge bg-@Model.DurumRenk me-1">@Model.DurumAdi</span>
                <span class="badge bg-secondary bg-opacity-10 text-secondary border">@Model.Oncelik</span>
            </div>
            @if (Model.Durum != IsEmriDurumu.Tamamlandi && Model.Durum != IsEmriDurumu.IptalEdildi)
            {
                <a href="/IsEmri/TutanakGiris/@Model.IsEmriId" class="btn btn-success">Tutanak Gir</a>
            }
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light border-0"><h6 class="fw-bold mb-0">Tüketim Noktası Bilgileri</h6></div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr><td class="text-muted fw-semibold" style="width:40%">Tüketim Noktası</td><td><strong>@(Model.TuketimNoktasiKodu ?? "-")</strong></td></tr>
                    <tr><td class="text-muted fw-semibold">Adres</td><td>@(Model.Adres ?? "-")</td></tr>
                    <tr><td class="text-muted fw-semibold">Sayaç Seri No</td><td>@(Model.SayacSeriNo ?? "-")</td></tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light border-0"><h6 class="fw-bold mb-0">Atama & Zamanlama</h6></div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr><td class="text-muted fw-semibold" style="width:40%">Planlanan Tarih</td><td><strong>@Model.PlanlananTarih.ToString("dd.MM.yyyy")</strong></td></tr>
                    <tr><td class="text-muted fw-semibold">Atanan Personel</td><td>@(Model.AtananKullaniciAdi ?? "Henüz atanmadı")</td></tr>
                    <tr><td class="text-muted fw-semibold">Oluşturulma</td><td class="small">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td></tr>
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <tr><td class="text-muted fw-semibold">Son Güncelleme</td><td class="small">@Model.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm")</td></tr>
                    }
                </table>
            </div>
        </div>
    </div>
</div>

@if (Model.TutanakGirildiMi)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-success bg-opacity-10 border-0">
            <h6 class="fw-bold mb-0 text-success">Tutanak Bilgileri - @Model.TutanakNo</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless mb-0">
                        <tr><td class="text-muted fw-semibold" style="width:40%">Saha Sonucu</td><td><strong>@Model.SahaSonucu</strong></td></tr>
                        @if (!string.IsNullOrEmpty(Model.Gerekce))
                        {
                            <tr><td class="text-muted fw-semibold">Gerekçe</td><td>@Model.Gerekce</td></tr>
                        }
                    </table>
                </div>
                @if (Model.IsSokmeTakma)
                {
                    <div class="col-md-6">
                        <table class="table table-borderless mb-0">
                            <tr><td class="text-muted fw-semibold" style="width:40%">Eski Sayaç No</td><td>@(Model.EskiSayacNo ?? "-")</td></tr>
                            <tr><td class="text-muted fw-semibold">Eski Son Endeks</td><td>@(Model.EskiSonEndeksi?.ToString("N2") ?? "-") kWh</td></tr>
                            <tr><td class="text-muted fw-semibold">Yeni Sayaç No</td><td>@(Model.YeniSayacNo ?? "-")</td></tr>
                            <tr><td class="text-muted fw-semibold">Yeni İlk Endeks</td><td>@(Model.YeniIlkEndeksi?.ToString("N2") ?? "-") kWh</td></tr>
                            <tr><td class="text-muted fw-semibold">Mühür No</td><td>@(Model.MuhurNo ?? "-")</td></tr>
                        </table>
                    </div>
                }
                @if (Model.IsAcmaKesme)
                {
                    <div class="col-md-6">
                        <table class="table table-borderless mb-0">
                            @if (Model.KesmeEndeksi.HasValue)
                            {
                                <tr><td class="text-muted fw-semibold" style="width:40%">Kesme Endeksi</td><td>@Model.KesmeEndeksi.Value.ToString("N2") kWh</td></tr>
                            }
                            @if (Model.AcmaEndeksi.HasValue)
                            {
                                <tr><td class="text-muted fw-semibold" style="width:40%">Açma Endeksi</td><td>@Model.AcmaEndeksi.Value.ToString("N2") kWh</td></tr>
                            }
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}
else if (Model.Durum != IsEmriDurumu.Tamamlandi && Model.Durum != IsEmriDurumu.IptalEdildi)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body text-center py-4">
            <p class="text-muted mb-3">Bu iş emri için henüz tutanak girilmemiştir.</p>
            <a href="/IsEmri/TutanakGiris/@Model.IsEmriId" class="btn btn-success">Tutanak Gir</a>
        </div>
    </div>
}
