@model IEnumerable<KcetasWeb.Models.Fatura>

@{
    ViewData["Title"] = "Fatura Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="h4 text-primary fw-bold">Kesilen Faturalar</h2>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-primary fw-bold">Filtrele / Ara</button>
        <a asp-action="Olustur" class="btn btn-primary fw-bold">
            <i class="bi bi-plus-lg"></i> Yeni Fatura Oluştur
        </a>
    </div>
</div>

@if (TempData["BasariMesaji"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["BasariMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Fatura No</th>
                        <th>Dönem</th>
                        <th>Sözleşme ID</th>
                        <th>Vergi ve Fonlar</th>
                        <th>Toplam Tutar</th>
                        <th>Son Ödeme</th>
                        <th>Durum</th>
                        <th class="pe-4 text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fatura in Model)
                    {
                        <tr>
                            <td class="ps-4"><strong>@fatura.fatura_no</strong></td>
                            <td><span class="badge bg-secondary">@fatura.donem</span></td>
                            <td>@fatura.sozlesme_id</td>
                            <td>₺@fatura.vergi_fon_toplama.ToString("0.00")</td>
                            <td class="fw-bold text-dark">₺@fatura.toplam_tutar.ToString("0.00")</td>
                            <td>@fatura.son_odeme_tarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if(fatura.durum == "Ödendi")
                                {
                                    <span class="badge bg-success">Ödendi</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@fatura.durum</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <a href="/Fatura/Detay/@fatura.fatura_id" class="btn btn-sm btn-light border text-primary shadow-sm">Detay</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>