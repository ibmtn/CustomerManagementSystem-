@model KcetasWeb.Models.Fatura

@{
    ViewData["Title"] = "Yeni Fatura Oluştur";
}

<div class="mb-4 mt-3">
    <h2 class="h4 text-primary fw-bold">Yeni Fatura Oluştur</h2>
    <p class="text-muted">Manuel olarak yeni bir fatura kaydı oluşturun.</p>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-4">
        <form asp-action="Olustur" method="post">
            
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Sözleşme ID</label>
                    <input asp-for="sozlesme_id" class="form-control" type="number" required />
                </div>
                
                <div class="col-md-6">
                    <label class="form-label fw-bold">Endeks Okuma ID</label>
                    <input asp-for="okuma_id" class="form-control" type="number" required />
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Toplam Tutar</label>
                    <div class="input-group">
                        <span class="input-group-text">₺</span>
                        <input asp-for="toplam_tutar" type="number" step="0.01" class="form-control" required />
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold">Vergi ve Fonlar</label>
                    <div class="input-group">
                        <span class="input-group-text">₺</span>
                        <input asp-for="vergi_fon_toplama" type="number" step="0.01" class="form-control" required />
                    </div>
                </div>
            </div>

            <div class="text-end mt-4 border-top pt-4">
                <a href="/Fatura/Index" class="btn btn-light border px-4 shadow-sm me-2 fw-bold">İptal</a>
                <button type="submit" class="btn btn-primary px-4 shadow-sm fw-bold"><i class="bi bi-check2-circle me-1"></i> Faturayı Oluştur</button>
            </div>
        </form>
    </div>
</div>
