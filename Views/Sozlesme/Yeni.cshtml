@{
    ViewData["Title"] = "Yeni Sözleşme";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="mb-3">
            <a href="/Sozlesme" class="btn btn-sm btn-outline-secondary">&larr; Listeye Geri Dön</a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white py-3">
                <h5 class="card-title mb-0 fw-bold">Yeni Perakende Satış Sözleşmesi</h5>
            </div>
            <div class="card-body p-4">
                <form action="/Sozlesme/Yeni" method="post">
                    
                    <h6 class="fw-bold text-primary border-bottom pb-2 mb-3">1. Tesisat Bilgileri</h6>
                    <div class="row mb-4">
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold">Tüketim Noktası ID <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="TuketimNoktasiId" placeholder="Örn: 1001" required />
                        </div>
                    </div>

                    <h6 class="fw-bold text-primary border-bottom pb-2 mb-3">2. Abone Bilgileri</h6>
                    <div class="row mb-4">
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold">Abone ID <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="AboneId" placeholder="Örn: 1" required />
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/Sozlesme" class="btn btn-light border">İptal</a>
                        <button type="submit" class="btn btn-success px-4">Sözleşmeyi Başlat</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>