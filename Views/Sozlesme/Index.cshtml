@model IEnumerable<KcetasWeb.Models.Sozlesme>

@{
    ViewData["Title"] = "Sözleşmeler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    @if (TempData["SozlesmeMesaji"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <strong>Harika!</strong> @TempData["SozlesmeMesaji"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <h2 class="h4 text-primary fw-bold">Perakende Satış Sözleşmeleri</h2>
    <a href="/Sozlesme/Yeni" class="btn btn-success fw-bold">+ Yeni Sözleşme Başlat</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Sözleşme No</th>
                        <th>Abone ID</th>
                        <th>Tüketim Noktası ID</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td><strong>@s.SozlesmeNo</strong></td>
                            <td>@s.AboneId</td>
                            <td><a href="#" class="text-decoration-none">@s.TuketimNoktasiId</a></td>
                            <td>
                                @if (s.Durum == "Aktif")
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else if (s.Durum == "Feshedildi")
                                {
                                    <span class="badge bg-danger">Feshedildi</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@s.Durum</span>
                                }
                            </td>
                            <td>
                                <a href="/Sozlesme/Detay/@s.SozlesmeNo" class="btn btn-sm btn-outline-primary">Detaylar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
