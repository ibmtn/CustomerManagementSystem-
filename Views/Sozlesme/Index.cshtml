@{
    ViewData["Title"] = "Sözleşmeler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    @if (TempData["SozlesmeMesaji"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
        <strong>Harika!</strong> @TempData["SozlesmeMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
    <h2 class="h4 text-primary fw-bold">Perakende Satış Sözleşmeleri</h2>
    <a href="/Sozlesme/Yeni" class="btn btn-success fw-bold">+ Yeni Sözleşme Başlat</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Sözleşme No</th>
                        <th>Abone Adı / Ünvanı</th>
                        <th>Tüketim Noktası (Tekil Kod)</th>
                        <th>Tarife Grubu</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>SZL-10045</strong></td>
                        <td>Ahmet Yılmaz</td>
                        <td><a href="#" class="text-decoration-none">TK-2026-001</a></td>
                        <td>Tek Zamanlı Mesken</td>
                        <td><span class="badge bg-success">Aktif</span></td>
                        <td><button class="btn btn-sm btn-outline-primary">Detay</button></td>
                    </tr>
                    <tr>
                        <td><strong>SZL-10046</strong></td>
                        <td>Örnek Ltd. Şti.</td>
                        <td><a href="#" class="text-decoration-none">TK-2026-002</a></td>
                        <td>Ticarethane</td>
                        <td><span class="badge bg-warning text-dark">Güvence Bekliyor</span></td>
                        <td><button class="btn btn-sm btn-outline-primary">Detay</button></td>
                    </tr>
                    <tr>
                        <td><strong>SZL-10047</strong></td>
                        <td>Ayşe Demir</td>
                        <td><a href="#" class="text-decoration-none">TK-2026-003</a></td>
                        <td>Mesken</td>
                        <td><span class="badge bg-danger">Feshedildi</span></td>
                        <td><button class="btn btn-sm btn-outline-primary">Detay</button></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>