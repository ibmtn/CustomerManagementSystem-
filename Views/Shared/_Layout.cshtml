<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Abone Yönetim Sistemi</title>
    
    <!-- Sadece Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">KCETAŞ Portal</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                
                <!-- SOL MENÜ: Sadece Giriş Yapanlar Görebilir -->
                <ul class="navbar-nav flex-grow-1">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-controller="TuketimNoktasi" asp-action="Index">Tüketim Noktaları</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-controller="Sozlesme" asp-action="Index">Sözleşmeler</a>
                        </li>
                        
                        <!-- ROL KONTROLÜ: Sadece 'Yonetici' rolü olanlar görür -->
                        @if (User.IsInRole("Yonetici"))
                        {
                            <li class="nav-item">
                               <!-- Eski hali: href="#" şeklindeydi, şimdi Controller ve Action verdik -->
<a class="nav-link text-danger fw-bold" asp-controller="Admin" asp-action="Index">Admin Paneli</a>
                            </li>
                        }
                    }
                </ul>

                <!-- SAĞ MENÜ: Kullanıcı Bilgisi ve Çıkış Butonu -->
                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item d-flex align-items-center me-3">
                            <span class="text-muted">Hoş geldin, <strong class="text-primary">@User.Identity?.Name</strong></span>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-danger btn-sm mt-1" asp-controller="Auth" asp-action="Logout">Çıkış Yap</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm mt-1" asp-controller="Auth" asp-action="Login">Giriş Yap</a>
                        </li>
                    }
                </ul>

            </div>
        </div>
    </nav>
</header>

    <main class="container my-5">
        @RenderBody()
    </main>

    <footer class="bg-white text-center text-muted py-3 border-top mt-auto fixed-bottom">
        <div class="container">
            <small>&copy; @DateTime.Now.Year - Elektrik Dağıtım MVP</small>
        </div>
    </footer>
</body>
</html>