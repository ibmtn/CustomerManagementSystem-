<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Abone Yönetim Sistemi</title>

    <!-- Sadece Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">

@if (User.Identity.IsAuthenticated)
{
    <!-- ÜST BAR: Hamburger buton her ekran boyutunda görünür -->
    <nav class="navbar navbar-light bg-white border-bottom">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand fw-bold text-primary mb-0" asp-controller="Home" asp-action="Index">KCETAŞ Portal</a>
            <span style="width:42px;"></span>
        </div>
    </nav>

    

    <!-- OFFCANVAS SIDEBAR: hem mobil hem PC için tek yapı -->
    <div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarOffcanvas">
        <div class="offcanvas-header border-bottom">
            <a class="navbar-brand fw-bold text-primary mb-0" asp-controller="Home" asp-action="Index">KCETAŞ Portal</a>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column">
            <partial name="_SidebarMenu" />
        </div>
    </div>

    <!-- İÇERİK -->
    <main class="container-fluid my-5">
        @RenderBody()
    </main>

    <footer class="bg-white text-center text-muted py-3 border-top">
        <div class="container">
            <small>&copy; @DateTime.Now.Year - Elektrik Dağıtım MVP</small>
        </div>
    </footer>
}
else
{
    <!-- GİRİŞ YAPILMAMIŞ DURUM: basit üst navbar, sidebar YOK -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">KCETAŞ Portal</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarGuest">
                    <span class="navbar-toggler-icon"></span>
                </button>
                        <div class="collapse navbar-collapse justify-content-end" id="navbarGuest">
            <ul class="navbar-nav">
                <li class="nav-item me-2">
                    <a class="btn btn-outline-primary btn-sm mt-1" asp-controller="Auth" asp-action="Register">Hesap Aç</a>
                </li>
                <li class="nav-item">
                    <a class="btn btn-primary btn-sm mt-1" asp-controller="Auth" asp-action="Login">Giriş Yap</a>
                </li>
            </ul>
        </div>
            </div>
        </nav>
    </header>

    <main class="container my-5">
        @RenderBody()
    </main>

    <footer class="bg-white text-center text-muted py-3 border-top">
        <div class="container">
            <small>&copy; @DateTime.Now.Year - Elektrik Dağıtım MVP</small>
        </div>
    </footer>
}

    <!-- Bootstrap JS Bundle (offcanvas ve collapse için ZORUNLU) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

