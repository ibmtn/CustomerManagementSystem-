@{
    ViewData["Title"] = "Yeni Endeks Okuma Girişi";
}

<div class="row justify-content-center mt-3">
    <div class="col-md-8">
        <div class="mb-3">
            <a href="/EndeksOkuma/Index" class="btn btn-sm btn-outline-secondary rounded-pill px-3 shadow-sm">&larr; Listeye Geri Dön</a>
        </div>

        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-primary text-white py-3 rounded-top-4">
                <h5 class="card-title mb-0 fw-bold"><i class="bi bi-speedometer me-2"></i> Yeni Endeks Okuma Girişi</h5>
            </div>
            <div class="card-body p-4 bg-light rounded-bottom-4">
                <form action="/EndeksOkuma/Yeni" method="post">
                    
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted small text-uppercase">Tüketim Noktası ID <span class="text-danger">*</span></label>
                            <input type="text" class="form-control form-control-lg shadow-sm font-monospace" name="TuketimNoktasiId" placeholder="Örn: 1001" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted small text-uppercase">Sayaç ID <span class="text-danger">*</span></label>
                            <input type="text" class="form-control form-control-lg shadow-sm font-monospace" name="SayacId" placeholder="Örn: 5001" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted small text-uppercase">İlk Endeks (kWh) <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" class="form-control form-control-lg shadow-sm" name="IlkEndeks" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted small text-uppercase">Son Endeks (kWh) <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" class="form-control form-control-lg shadow-sm border-primary" name="SonEndeks" required />
                        </div>
                    </div>

                    <div class="alert alert-info shadow-sm rounded-3 border-0">
                        <i class="bi bi-info-circle-fill me-2"></i> Tüketim miktarı, güncel endeksten önceki endeks çıkarılarak otomatik olarak hesaplanacaktır.
                    </div>

                    <hr class="text-muted mb-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/EndeksOkuma/Index" class="btn btn-light border rounded-pill px-4">İptal</a>
                        <button type="submit" class="btn btn-primary shadow-sm rounded-pill px-4 fw-bold"><i class="bi bi-check-lg me-1"></i> Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
