@model List<KcetasWeb.ViewModels.EndeksOkumaViewModels>

@{
    ViewData["Title"] = "Endeks Okumaları";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-0 text-gray-800 fw-bold">
                <i class="bi bi-speedometer2 text-primary me-2"></i> Endeks Okumaları
            </h2>
            <p class="text-muted mt-1 mb-0">Saha ve uzaktan endeks okuma kayıtlarının listesi.</p>
        </div>
        <a href="/EndeksOkuma/Yeni" class="btn btn-primary shadow-sm rounded-pill px-4 fw-bold">
            <i class="bi bi-plus-lg me-1"></i> Yeni Okuma Girişi
        </a>
    </div>

    @if (TempData["OkumaMesaji"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 d-flex align-items-center rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
            <div>@TempData["OkumaMesaji"]</div>
        </div>
    }

    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-white py-3 border-bottom-0">
            <h6 class="m-0 font-weight-bold text-primary">Tüm Kayıtlar</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Okuma No</th>
                            <th>Okuma Tarihi</th>
                            <th>Abone</th>
                            <th>Okuma Tipi</th>
                            <th>Okuma Kaynağı</th>
                            <th>Sözleşme ID</th>
                            <th>Sayac ID</th>
                            <th>İlk Endeks</th>
                            <th>Son Endeks</th>
                            <th>Tüketim (kWh)</th>
                            <th>Durum</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var tuketim = (item.yeni_endeks ?? 0) - (item.onceki_endeks ?? 0);
                            <tr>
                                <td class="ps-4 fw-bold">@item.okuma_id</td>
                                <td>
                                    <span class="fw-bold text-dark">@item.okuma_zamani?.ToString("dd.MM.yyyy")</span>
                                    <br><small class="text-muted">@item.okuma_zamani?.ToString("HH:mm")</small>
                                </td>
                                <td>@item.abone</td>
                                <td><span class="badge bg-light text-dark border fw-bold px-2 py-1 shadow-sm">@item.okuma_tipi</span></td>
                                <td><span class="badge bg-primary px-2 py-1 shadow-sm text-white">@item.okuma_kaynagi</span></td>
                                <td><span class="text-secondary fw-medium">@item.sozlesme_id</span></td>
                                <td><span class="font-monospace text-primary fw-medium">@item.sayac_id</span></td>
                                <td>@item.onceki_endeks</td>
                                <td>@item.yeni_endeks</td>
                                <td>
                                    <span class="fw-bold @(tuketim > 1000 ? "text-danger" : "text-dark")">
                                        @tuketim.ToString("0.00")
                                    </span>
                                </td>
                                <td>
                                    @if (item.status == "Basarili" || item.status == "Başarılı")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3">Başarılı</span>
                                    }
                                    else if (item.status == "ACTIVE" || item.status == "AKTIF" || item.status == "Aktif")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3">Aktif</span>
                                    }
                                    else if (item.status == "Anormal")
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3">Anormal</span>
                                    }
                                    else if (item.status == "Hatali")
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3">Hatalı</span>
                                    }
                                    else if (item.status == "SifirTuketim")
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3">Sıfır Tüketim</span>
                                    }
                                    else if (item.status == "PASIF" || item.status == "Pasif")
                                    {
                                        <span class="badge bg-secondary text-white rounded-pill px-3 shadow-sm">Pasif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark text-white rounded-pill px-3 shadow-sm">@item.status</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light border" type="button" data-bs-toggle="dropdown">
                                            İşlem <i class="bi bi-chevron-down ms-1"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                            <li>
                                                <a href="/EndeksOkuma/Detay/@item.okuma_id" class="dropdown-item fw-semibold">
                                                    <i class="bi bi-eye text-primary me-2"></i> Detay
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                        
                        @if(Model.Count == 0)
                        {
                            <tr>
                                <td colspan="10" class="text-center py-4 text-muted">Kayıtlı endeks okuması bulunmamaktadır.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
