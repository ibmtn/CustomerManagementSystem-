@model List<KcetasWeb.Models.EndeksOkuma>

@{
    ViewData["Title"] = "Endeks Okumaları";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-0 text-gray-800 fw-bold">
                <i class="bi bi-speedometer2 text-primary me-2"></i> Endeks Okumaları
            </h2>
            <p class="text-muted mt-1 mb-0">Saha ve uzaktan endeks okuma kayıtlarının listesi.</p>
        </div>
        <a href="/EndeksOkuma/Yeni" class="btn btn-primary shadow-sm rounded-pill px-4 fw-bold">
            <i class="bi bi-plus-lg me-1"></i> Yeni Okuma Girişi
        </a>
    </div>

    @if (TempData["OkumaMesaji"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 d-flex align-items-center rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
            <div>@TempData["OkumaMesaji"]</div>
        </div>
    }

    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-white py-3 border-bottom-0">
            <h6 class="m-0 font-weight-bold text-primary">Tüm Kayıtlar</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Okuma Tarihi</th>
                            <th>Tüketim Noktası</th>
                            <th>Sayaç Seri No</th>
                            <th>Tüketim (kWh)</th>
                            <th>Durum</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold text-dark">@item.OkumaTarihi.ToString("dd.MM.yyyy")</span>
                                    <br><small class="text-muted">@item.OkumaTarihi.ToString("HH:mm")</small>
                                </td>
                                <td><span class="font-monospace text-primary fw-medium">@item.TuketimNoktasiId</span></td>
                                <td>@item.SayacId</td>
                                <td>
                                    <span class="fw-bold @(item.TuketimMiktari > 1000 ? "text-danger" : "text-dark")">
                                        @item.TuketimMiktari.ToString("0.00")
                                    </span>
                                </td>
                                <td>
                                    @if (item.Durum == "Başarılı")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3">@item.Durum</span>
                                    }
                                    else if (item.Durum == "Anormal")
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3">@item.Durum</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-3">@item.Durum</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <a href="/EndeksOkuma/Detay/@item.EndeksOkumaId" class="btn btn-sm btn-outline-primary shadow-sm rounded-pill px-3">Detay</a>
                                </td>
                            </tr>
                        }
                        
                        @if(Model.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">Kayıtlı endeks okuması bulunmamaktadır.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
